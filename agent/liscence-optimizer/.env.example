# =============================================================================
# SSL Configuration
# =============================================================================
# Disable SSL certificate verification for local development only.
# NEVER set to true in production.
DISABLE_SSL_VERIFICATION=false

# ============================================================================
# Azure OpenAI Configuration
# ============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ============================================================================
# Azure Cosmos DB Configuration
# ============================================================================
COSMOSDB_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOSDB_KEY=your-cosmos-key
COSMOSDB_DATABASE_NAME=agenticai

# ============================================================================
# Observability — Grafana OTLP (SDK 1.2.0+)
# ============================================================================
# OTLP endpoint for Grafana Cloud (Tempo + Loki + Prometheus).
# Use RUNTIME_OTLP_ENDPOINT (not OTEL_EXPORTER_OTLP_ENDPOINT) to avoid
# conflicting with the OTel SDK's own auto-configuration.
RUNTIME_OTLP_ENDPOINT=https://otlp-gateway-<stack>.grafana.net/otlp

# Base64-encoded "Authorization: Basic <token>" header for Grafana Cloud.
# To create: echo -n "INSTANCE_ID:TOKEN" | base64
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<BASE64_ENCODED_TOKEN>

# Service identity (used as OTel resource attributes)
OTEL_SERVICE_NAME=liscence-optimizer
DEPLOYMENT_ENVIRONMENT=development

# Prevent the OTel SDK from auto-exporting logs via its own exporter
# (the SDK uses a custom _TruncatingLogExporter instead)
OTEL_LOGS_EXPORTER=none

# Beat identifier — used in resource_attributes.beat_id for Grafana dashboard filtering.
# Uncomment and set when deploying to a known beat environment.
# BEAT_ID=unknown

# ============================================================================
# Azure AD Authentication
# Required for production deployment with Azure Container Apps Easy Authentication
# ============================================================================
AZURE_TENANT_ID=fcb2b37b-5da0-466b-9b83-0014b67a7c78
AZURE_CLIENT_ID=6a99f31c-bf54-4a3c-89e8-bb3e5b108a25
MANAGED_IDENTITY_CLIENT_ID=906f830e-eeab-46e1-9e90-ad410c8649a3

# ============================================================================
# Authentication Configuration
# ============================================================================
# Set to false for local development, true for production
APP_AUTHENTICATION__ENABLED=false
APP_AUTHENTICATION__REQUIRE_AUTH=false

# ============================================================================
# Server Configuration
# ============================================================================
PORT=8000
HOST=0.0.0.0

# ============================================================================
# Debug Configuration (optional)
# ============================================================================
DEBUGPY_ENABLE=false
DEBUGPY_WAIT=false
DEBUGPY_PORT=5678