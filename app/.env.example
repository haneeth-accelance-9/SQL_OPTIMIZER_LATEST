# Copy to .env and set values. Never commit .env.
# First-time: create a user with: python manage.py createsuperuser

# Logging level for the app and root logger (DEBUG | INFO | WARNING | ERROR)
# Use DEBUG locally, INFO in staging/prod.
LOG_LEVEL=INFO

# Required in production (leave unset or set for dev)
DJANGO_SECRET_KEY=change-me-generate-with-python-c-import-secrets-print-secrets-token_urlsafe-50
# Production: set to production and set DJANGO_SECRET_KEY and ALLOWED_HOSTS
DJANGO_ENV=
# Debug mode (default True for dev; must be False in production)
DJANGO_DEBUG=True
# Comma-separated hosts (required in production)
ALLOWED_HOSTS=localhost,127.0.0.1

# USU / Demand API credentials (required — never use defaults in production)
USU_API_USERNAME=your-usu-api-username
USU_API_PASSWORD=your-usu-api-password
# Pre-computed Basic auth header: base64("username:password")
# Generate: python -c "import base64; print('Basic ' + base64.b64encode(b'user:pass').decode())"
DEMAND_API_AUTH_HEADER=Basic <base64-encoded-user:password>

# Optional: Azure OpenAI for AI-generated reports
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Optional: Azure API Management gateway (routes LLM calls through APIM)
# When set, AZURE_APIM_ENDPOINT overrides AZURE_OPENAI_ENDPOINT for all LLM requests.
# AZURE_APIM_SUB_KEY is sent as Ocp-Apim-Subscription-Key on every request.
AZURE_APIM_ENDPOINT=https://your-apim.azure-api.net/openai
AZURE_APIM_SUB_KEY=

# Optional: Excel sheet names (defaults used if not set)
# EXCEL_SHEET_INSTALLATIONS=MVP - Data 1 - Installation
# EXCEL_SHEET_DEMAND=MVP - Data 2 - Demand Results
# EXCEL_SHEET_PRICES=MVP - Data 3 - Prices
# EXCEL_SHEET_OPTIMIZATION=MVP - Data 4 - Optimization potential
# EXCEL_SHEET_HELPFUL_REPORTS=Helpful Reports
